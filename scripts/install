#!/usr/bin/env bash
# Skilless Installer
# Usage: curl -LsSf https://skilless.ai/install | bash
# Flags: --dev (use main branch), --china (use Tsinghua mirror)

set -e

REPO="brikerman/skilless.ai"
SKILLS_DIR="$HOME/.agents/skills"
INSTALL_DIR="$SKILLS_DIR/skilless"
GITHUB_API="https://api.github.com/repos/$REPO/releases/latest"
GITHUB_RELEASE="https://github.com/$REPO/releases/latest/download"

# ---- Parse arguments ----
DEV=false
CHINA=false
for arg in "$@"; do
  case "$arg" in
    --dev)   DEV=true ;;
    --china) CHINA=true ;;
  esac
done

# ---- Header ----
echo ""
echo "  ✨ Skilless Installer"
echo "  ─────────────────────"
echo ""

# ---- System info ----
OS="$(uname -s)"
ARCH_RAW="$(uname -m)"

case "$OS" in
  Darwin) PLATFORM="macos" ;;
  Linux)  PLATFORM="linux" ;;
  *)      echo "  ✗ Unsupported OS: $OS"; exit 1 ;;
esac

case "$ARCH_RAW" in
  x86_64|amd64)  ARCH="x86_64" ;;
  arm64|aarch64) ARCH="aarch64" ;;
  *)             echo "  ✗ Unsupported architecture: $ARCH_RAW"; exit 1 ;;
esac

echo "  System : ${PLATFORM}/${ARCH}"

# ---- Local version ----
CURRENT_VERSION=""
if [ -f "$INSTALL_DIR/VERSION" ]; then
  CURRENT_VERSION="$(cat "$INSTALL_DIR/VERSION" 2>/dev/null || echo "")"
  echo "  Local  : v${CURRENT_VERSION}"
else
  echo "  Local  : not installed"
fi

# ---- Determine download source ----
if [ "$DEV" = "true" ]; then
  ASSET_NAME="main.zip"
  DOWNLOAD_URL="https://github.com/$REPO/archive/refs/heads/main.zip"
  LATEST_VERSION="dev"
  echo "  Mode   : dev (main branch)"
  echo ""
else
  echo "  Checking latest release..."
  LATEST_VERSION="$(curl -fsSL "$GITHUB_API" 2>/dev/null \
    | grep '"tag_name"' \
    | sed -E 's/.*"tag_name": *"release\/v?([^"]+)".*/\1/' \
    | head -1)"

  if [ -z "$LATEST_VERSION" ]; then
    echo "  ✗ Failed to fetch latest version from GitHub"
    exit 1
  fi

  echo "  Latest : v${LATEST_VERSION}"
  echo ""

  if [ -n "$CURRENT_VERSION" ] && [ "$CURRENT_VERSION" = "$LATEST_VERSION" ]; then
    echo "  ✓ Already up to date (v${CURRENT_VERSION})"
    echo ""
    echo "  Usage:"
    echo "    cd $INSTALL_DIR && uv run scripts/cli.py doctor"
    echo "    cd $INSTALL_DIR && uv run scripts/cli.py search <query>"
    echo ""
    exit 0
  fi

  ASSET_NAME="skilless.zip"
  DOWNLOAD_URL="${GITHUB_RELEASE}/${ASSET_NAME}"
fi

# ---- Download ----
echo "  ↓ Downloading..."
TMPDIR_WORK="$(mktemp -d)"
trap 'rm -rf "$TMPDIR_WORK"' EXIT

if ! curl -fsSL -o "$TMPDIR_WORK/$ASSET_NAME" "$DOWNLOAD_URL" 2>/dev/null; then
  echo "  ✗ Failed to download: $DOWNLOAD_URL"
  echo "  See https://github.com/$REPO/releases for available releases."
  exit 1
fi

echo "  ✓ Downloaded"

# ---- Extract to skilless-repo ----
echo "  ↓ Extracting..."
unzip -qo "$TMPDIR_WORK/$ASSET_NAME" -d "$TMPDIR_WORK/skilless-repo"

# GitHub archive ZIPs have an inner dir (e.g. skilless.ai-main/); release ZIPs do not
if [ "$DEV" = "true" ]; then
  SRC_DIR="$(find "$TMPDIR_WORK/skilless-repo" -maxdepth 1 -mindepth 1 -type d | head -1)"
else
  SRC_DIR="$TMPDIR_WORK/skilless-repo"
fi

echo "  ✓ Extracted"

# ---- Copy src/* -> ~/.agents/skills/ ----
echo "  ↓ Installing files..."
mkdir -p "$SKILLS_DIR"
cp -a "$SRC_DIR/src/." "$SKILLS_DIR/"
# Copy README files to skilless/
for f in "$SRC_DIR"/README*.md; do
  [ -f "$f" ] && cp -f "$f" "$INSTALL_DIR/"
done
echo "  ✓ Files installed"

# ---- Check / install uv ----
if command -v uv &>/dev/null; then
  echo "  ✓ uv found: $(uv --version)"
else
  echo "  ↓ Installing uv (Python package manager)..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="$HOME/.local/bin:$PATH"
  echo "  ✓ uv installed: $(uv --version)"
fi

# ---- Mirror selection ----
UV_INDEX_URL="https://pypi.org/simple"
if [ "$CHINA" = "true" ]; then
  UV_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
  echo "  → Using China mirror (Tsinghua)"
elif ! curl -sI --connect-timeout 3 https://pypi.org &>/dev/null; then
  echo "  → China network detected, switching to Tsinghua mirror"
  UV_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
fi

# ---- Virtual environment ----
echo "  ↓ Setting up virtual environment..."
uv venv "$INSTALL_DIR/.venv" --python ">=3.12" --quiet 2>/dev/null
PY_VER="$("$INSTALL_DIR/.venv/bin/python" --version 2>&1 | awk '{print $2}')"
echo "  ✓ Virtual environment ready (Python ${PY_VER})"

# ---- Install dependencies ----
echo "  ↓ Installing dependencies..."
uv pip install --python "$INSTALL_DIR/.venv/bin/python" \
  "$INSTALL_DIR" \
  --index-url "$UV_INDEX_URL" \
  --quiet 2>/dev/null
echo "  ✓ Dependencies installed"

# ---- CLI wrapper ----
cat > "$INSTALL_DIR/skilless" << 'WRAPPER'
#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
exec "$SCRIPT_DIR/.venv/bin/python" "$SCRIPT_DIR/scripts/cli.py" "$@"
WRAPPER
chmod +x "$INSTALL_DIR/skilless"

# ---- Done ----
NEW_VERSION="$(cat "$INSTALL_DIR/VERSION" 2>/dev/null || echo "unknown")"
[ "$DEV" = "true" ] && NEW_VERSION="${NEW_VERSION}-dev"

echo ""
echo "  ✓ Skilless v${NEW_VERSION} installed!"
echo ""
echo "  Usage:"
echo "    cd $INSTALL_DIR && uv run scripts/cli.py doctor"
echo "    cd $INSTALL_DIR && uv run scripts/cli.py search <query>"
echo ""
echo "  Please restart VS Code / OpenCode / Copilot or reload your Agent to enable the skills."
echo ""

cd "$INSTALL_DIR" && uv run scripts/cli.py doctor 2>/dev/null || true
