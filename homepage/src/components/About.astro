---
import { Github, ArrowRight, Rocket } from 'lucide-astro';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-16 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-3xl mx-auto px-6">

    <!-- Terminal Window -->
    <div class="border border-gray-300 dark:border-gray-700 rounded-xl shadow-lg overflow-hidden">

      <!-- Window Chrome -->
      <div class="bg-gray-100 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-4 py-2.5 flex items-center gap-2">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-red-400 border border-red-500/40"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-400 border border-yellow-500/40"></div>
          <div class="w-3 h-3 rounded-full bg-green-400 border border-green-500/40"></div>
        </div>
        <div class="flex-1 text-center text-xs font-medium font-mono text-gray-500 dark:text-gray-400">
          terminal — credits.sh
        </div>
      </div>

      <!-- Terminal Content -->
      <div class="p-5 bg-white dark:bg-gray-900 font-mono text-xs space-y-3">

        <!-- Prompt -->
        <div class="flex items-center gap-2">
          <span class="text-green-600 dark:text-green-400">➜</span>
          <span class="text-blue-600 dark:text-blue-400">~</span>
          <span class="text-gray-700 dark:text-gray-300">cat credits.sh</span>
        </div>

        <div class="h-px bg-gray-200 dark:bg-gray-700 my-1"></div>

        <!-- Author comment -->
        <div class="text-gray-400 dark:text-gray-500"># {t('about.label.author')}</div>

        <!-- Author card -->
        <div class="bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-950/30 dark:to-indigo-950/30 border border-blue-200 dark:border-blue-800/60 rounded-lg p-3">
          <div class="flex items-center gap-3 mb-2.5">
            <img
              src="https://avatars.githubusercontent.com/u/9368907?v=4"
              alt={t('about.name')}
              class="w-11 h-11 rounded-lg border-2 border-blue-300 dark:border-blue-700 flex-shrink-0"
              loading="lazy"
            />
            <div class="flex-1 min-w-0">
              <div class="text-sm font-bold text-gray-900 dark:text-gray-100 mb-0.5">{t('about.name')}</div>
              <div class="text-[11px] text-gray-600 dark:text-gray-400">{t('about.role')} @ Yodo1</div>
            </div>
          </div>

          <div class="flex flex-wrap gap-1.5 mb-2.5">
            <span class="px-2 py-0.5 bg-blue-500 text-white rounded text-[10px] font-semibold">Google Developer Expert</span>
            <span class="px-2 py-0.5 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded text-[10px] font-medium">AI Builder</span>
            <span class="px-2 py-0.5 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded text-[10px] font-medium">Engineer</span>
          </div>

          <a
            href="https://github.com/BrikerMan"
            target="_blank"
            class="inline-flex items-center gap-1.5 text-blue-700 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300 font-semibold transition-colors"
          >
            <Github size={13} strokeWidth={2} />
            <span>@BrikerMan</span>
            <ArrowRight size={11} strokeWidth={2} />
          </a>
        </div>

        <div class="h-px bg-gray-200 dark:bg-gray-700 my-1"></div>

        <!-- Company comment -->
        <div class="text-gray-400 dark:text-gray-500"># {t('about.label.company')}</div>

        <!-- Company card -->
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-3 bg-gray-50 dark:bg-gray-800/50">
          <div class="flex items-start gap-2.5 mb-2.5">
            <div class="h-8 flex items-center justify-center flex-shrink-0">
              <img
                src="https://cdn.prod.website-files.com/6887bf4736a1af9bcda0d776/6888c8081469b2c2066f198b_yodo1_logo_web.png.webp"
                alt="Yodo1"
                class="h-6 w-auto object-contain dark:invert"
                loading="lazy"
              />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <span class="text-sm font-bold text-gray-900 dark:text-gray-100">Yodo1</span>
                <span class="px-2 py-0.5 bg-gradient-to-r from-amber-400 to-orange-400 text-white rounded text-[10px] font-bold shadow-sm">
                  🏆 {t('about.yodo1.badge')}
                </span>
              </div>
              <p class="text-[11px] text-gray-600 dark:text-gray-400 leading-relaxed">{t('about.yodo1.desc')}</p>
            </div>
          </div>

          <div class="bg-gradient-to-r from-purple-50 to-pink-50 dark:from-purple-950/30 dark:to-pink-950/30 border border-purple-200 dark:border-purple-800/50 rounded px-3 py-2 mb-2.5">
            <p class="text-xs font-semibold text-purple-900 dark:text-purple-300">💡 {t('about.yodo1.pitch')}</p>
          </div>

          <a
            href="https://www.yodo1.com/careers"
            target="_blank"
            class="group flex items-center justify-center gap-2 bg-gray-900 dark:bg-white hover:bg-gray-700 dark:hover:bg-gray-100 text-white dark:text-gray-900 px-3 py-2 rounded text-xs font-semibold transition-colors"
          >
            <Rocket size={13} strokeWidth={1.5} />
            <span>{t('about.yodo1.cta')}</span>
            <ArrowRight size={11} strokeWidth={2} class="group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>

        <!-- Cursor line -->
        <div class="flex items-center gap-2 pt-1">
          <span class="text-green-600 dark:text-green-400">➜</span>
          <span class="text-blue-600 dark:text-blue-400">~</span>
          <span class="text-gray-400 dark:text-gray-600 animate-pulse">█</span>
        </div>

      </div>
    </div>
  </div>
</section>

