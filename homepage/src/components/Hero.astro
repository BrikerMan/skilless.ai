---
import { Apple, Monitor, Copy, ChevronDown, Bot } from 'lucide-astro';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const macCmd = lang === 'zh'
  ? 'curl -LsSf https://skilless.ai/install | bash -s -- --china'
  : 'curl -LsSf https://skilless.ai/install | bash';
const winCmd = lang === 'zh'
  ? '& ([scriptblock]::Create((Invoke-RestMethod https://skilless.ai/install.ps1))) -China'
  : 'Invoke-RestMethod https://skilless.ai/install.ps1 | Invoke-Expression';

const llmPrompt = `Please help me install skilless.ai on my computer. It's an open-source AI skill library (github.com/brikerman/skilless.ai).

Run this command in my terminal to install:

\`\`\`bash
${macCmd}
\`\`\`

If I'm on Windows, use PowerShell instead:
\`\`\`powershell
${winCmd}
\`\`\`

The installer will:
1. Download the latest release from GitHub (github.com/brikerman/skilless.ai)
2. Install uv (ultra-fast Python package manager) if not present
3. Create an isolated virtual environment at ~/.agents/skills/skilless/
4. Install all dependencies (yt-dlp, fastmcp, jina reader, feedparser)
5. Generate the skilless CLI executable

Everything stays isolated in ~/.agents/skills/ — no sudo required, zero system pollution.

After installation, please restart the agent or reload the window to enable the new skills.

Available skills after install:
- skilless.ai-brainstorming — Turn ideas into plans through collaborative dialogue
- skilless.ai-research — Search web, read pages, extract video subtitles, media processing
- skilless.ai-writing — Research-backed articles, emails, docs, and reports

To upgrade later, just re-run the same install command.`;

const macCmdHtml = lang === 'zh'
  ? `<span class="text-sky-500 dark:text-sky-400">curl</span><span class="text-gray-400 dark:text-gray-500"> -LsSf </span><span class="text-emerald-500 dark:text-emerald-400">https://skilless.ai/install</span><span class="text-amber-400"> | </span><span class="text-sky-500 dark:text-sky-400">bash</span><span class="text-gray-400 dark:text-gray-500"> -s -- --china</span>`
  : `<span class="text-sky-500 dark:text-sky-400">curl</span><span class="text-gray-400 dark:text-gray-500"> -LsSf </span><span class="text-emerald-500 dark:text-emerald-400">https://skilless.ai/install</span><span class="text-amber-400"> | </span><span class="text-sky-500 dark:text-sky-400">bash</span>`;

const winCmdHtml = lang === 'zh'
  ? `<span class="text-sky-500 dark:text-sky-400">&</span> <span class="text-gray-400 dark:text-gray-500">([scriptblock]::Create((</span><span class="text-sky-500 dark:text-sky-400">irm</span> <span class="text-emerald-500 dark:text-emerald-400">https://skilless.ai/install.ps1</span><span class="text-gray-400 dark:text-gray-500">)))</span> <span class="text-amber-400">-China</span>`
  : `<span class="text-sky-500 dark:text-sky-400">irm</span> <span class="text-emerald-500 dark:text-emerald-400">https://skilless.ai/install.ps1</span><span class="text-amber-400"> | </span><span class="text-sky-500 dark:text-sky-400">iex</span>`;
---

<section class="py-20 px-6">
  <div class="max-w-2xl mx-auto text-center">

    <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.15] mb-5 text-gray-900 dark:text-white">
      {t('hero.title.1')}<br />{t('hero.title.2')}
    </h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed max-w-md mx-auto mb-4">
      {t('hero.subtitle')}<br />{t('hero.subtitle2')}
    </p>
    <p class="text-sm text-gray-400 dark:text-gray-500 mb-10">
      {t('hero.desc.1')}<br />
      {t('hero.desc.2')} <strong class="text-gray-500 dark:text-gray-400">{t('hero.desc.strong')}</strong> {t('hero.desc.3')}
    </p>

    <!-- Install Box -->
    <div id="install-box" class="max-w-xl mx-auto rounded-xl border border-gray-200 dark:border-gray-800 overflow-hidden shadow-sm bg-white dark:bg-gray-900">
      <!-- Tabs -->
      <div class="flex border-b border-gray-200 dark:border-gray-800 text-sm">
        <button class="tab-btn active relative px-5 py-2.5 flex items-center gap-2 text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" data-target="cmd-mac">
          <Apple size={16} strokeWidth={1.5} /> {t('hero.tab.mac')}
        </button>
        <button class="tab-btn relative px-5 py-2.5 flex items-center gap-2 text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" data-target="cmd-win">
          <Monitor size={16} strokeWidth={1.5} /> {t('hero.tab.win')}
        </button>
        <button class="tab-btn relative px-5 py-2.5 flex items-center gap-2 text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" data-target="cmd-llm">
          <Bot size={16} strokeWidth={1.5} /> {t('hero.tab.llm')}
        </button>
      </div>

      <!-- Mac panel -->
      <div id="cmd-mac" class="cmd-panel flex items-start justify-between gap-3 px-5 py-3.5 bg-gray-50 dark:bg-gray-950 font-mono text-sm">
        <div class="text-gray-700 dark:text-gray-300 min-w-0 break-all text-left">
          <span class="text-green-500 dark:text-green-400 select-none mr-2">$</span><span set:html={macCmdHtml} />
        </div>
        <button class="copy-btn flex-shrink-0 p-1.5 rounded text-gray-400 dark:text-gray-600 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" data-copy={macCmd} title={t('hero.copy')}>
          <Copy size={16} strokeWidth={1.5} />
        </button>
      </div>

      <!-- Win panel -->
      <div id="cmd-win" class="cmd-panel hidden items-start justify-between gap-3 px-5 py-3.5 bg-gray-50 dark:bg-gray-950 font-mono text-sm">
        <div class="text-gray-700 dark:text-gray-300 min-w-0 break-all text-left">
          <span class="text-gray-400 dark:text-gray-500 select-none mr-2">&gt;</span><span set:html={winCmdHtml} />
        </div>
        <button class="copy-btn flex-shrink-0 p-1.5 rounded text-gray-400 dark:text-gray-600 hover:text-gray-700 dark:hover:text-gray-300 transition-colors" data-copy={winCmd} title={t('hero.copy')}>
          <Copy size={16} strokeWidth={1.5} />
        </button>
      </div>

      <!-- LLM panel -->
      <div id="cmd-llm" class="cmd-panel hidden px-5 py-4 bg-gray-50 dark:bg-gray-950">
        <div class="flex items-center justify-between gap-3 mb-3">
          <p class="text-xs text-gray-500 dark:text-gray-400 font-sans leading-relaxed text-left">{t('hero.llm.hint')}</p>
          <button class="copy-btn flex-shrink-0 flex items-center gap-1.5 text-xs text-gray-400 dark:text-gray-600 hover:text-gray-700 dark:hover:text-gray-300 transition-colors border border-gray-200 dark:border-gray-700 rounded px-2.5 py-1 bg-white dark:bg-gray-900" data-copy={llmPrompt} title={t('hero.copy.llm')}>
            <Copy size={13} strokeWidth={1.5} />
            <span class="copy-label font-sans">{t('hero.copy.llm')}</span>
          </button>
        </div>
        <div class="relative">
          <pre id="hero-llm-pre" class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-lg px-4 py-3 text-left text-xs text-gray-500 dark:text-gray-400 leading-relaxed whitespace-pre-wrap break-words font-mono max-h-[14em] overflow-hidden transition-[max-height] duration-300"><code set:text={llmPrompt} /></pre>
          <button id="hero-llm-toggle" class="w-full mt-1 text-xs text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors flex items-center justify-center gap-1 py-1" data-expand={t('hero.llm.expand')} data-collapse={t('hero.llm.collapse')}>
            <ChevronDown size={14} strokeWidth={1.5} class="hero-llm-chevron transition-transform duration-200" />
            <span class="hero-llm-toggle-label">{t('hero.llm.expand')}</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Install info toggle -->
    <div class="max-w-lg mx-auto mt-3">
      <button class="install-toggle w-full flex items-center justify-center gap-1.5 text-xs text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-400 py-2 transition-colors" id="install-toggle">
        <span>{t('hero.install.toggle')}</span>
        <ChevronDown size={12} strokeWidth={1.5} />
      </button>
      <div class="install-details" id="install-details">
        <div class="mt-2 border border-gray-200 dark:border-gray-800 rounded-xl bg-gray-50 dark:bg-gray-900 px-5 py-4 text-left text-sm text-gray-600 dark:text-gray-400 space-y-3">
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-5 h-5 rounded bg-gray-200 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs font-mono font-bold flex items-center justify-center">1</span>
            <div><strong class="text-gray-800 dark:text-gray-200">{t('hero.install.step1.title')}</strong> {t('hero.install.step1.desc')} <code class="text-xs bg-gray-200 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono text-gray-700 dark:text-gray-300">github.com/brikerman/skilless.ai</code></div>
          </div>
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-5 h-5 rounded bg-gray-200 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs font-mono font-bold flex items-center justify-center">2</span>
            <div><strong class="text-gray-800 dark:text-gray-200">{t('hero.install.step2.title')}</strong> {t('hero.install.step2.desc')}</div>
          </div>
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-5 h-5 rounded bg-gray-200 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs font-mono font-bold flex items-center justify-center">3</span>
            <div><strong class="text-gray-800 dark:text-gray-200">{t('hero.install.step3.title')}</strong> {t('hero.install.step3.desc')} <code class="text-xs bg-gray-200 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono text-gray-700 dark:text-gray-300">~/.agents/skills/</code> {t('hero.install.step3.desc2')} <code class="text-xs bg-gray-200 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono text-gray-700 dark:text-gray-300">yt-dlp</code> <code class="text-xs bg-gray-200 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono text-gray-700 dark:text-gray-300">fastmcp</code></div>
          </div>
          <div class="flex items-start gap-3">
            <span class="flex-shrink-0 w-5 h-5 rounded bg-gray-200 dark:bg-gray-800 text-gray-600 dark:text-gray-400 text-xs font-mono font-bold flex items-center justify-center">4</span>
            <div><strong class="text-gray-800 dark:text-gray-200">{t('hero.install.step4.title')}</strong> {t('hero.install.step4.desc')} <code class="text-xs bg-gray-200 dark:bg-gray-800 px-1.5 py-0.5 rounded font-mono text-gray-700 dark:text-gray-300">skilless.ai</code> {t('hero.install.step4.desc2')}</div>
          </div>
          <p class="text-xs text-gray-400 dark:text-gray-500 pt-2 border-t border-gray-200 dark:border-gray-700">{t('hero.install.footer')}</p>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.cmd-panel').forEach(p => p.classList.add('hidden'));
      btn.classList.add('active');
      const target = btn.getAttribute('data-target');
      if (target) {
        document.getElementById(target)?.classList.remove('hidden');
      }
    });
  });

  // Copy
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.getAttribute('data-copy') || '';
      navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });

  // Install details toggle
  const toggleBtn = document.getElementById('install-toggle');
  const details = document.getElementById('install-details');
  if (toggleBtn && details) {
    toggleBtn.addEventListener('click', () => {
      details.classList.toggle('open');
      toggleBtn.classList.toggle('open');
    });
  }

  // LLM prompt expand/collapse
  const heroLlmPre = document.getElementById('hero-llm-pre');
  const heroLlmToggle = document.getElementById('hero-llm-toggle');
  if (heroLlmPre && heroLlmToggle) {
    let expanded = false;
    heroLlmToggle.addEventListener('click', () => {
      expanded = !expanded;
      heroLlmPre.style.maxHeight = expanded ? heroLlmPre.scrollHeight + 'px' : '14em';
      heroLlmPre.style.overflow = expanded ? 'auto' : 'hidden';
      heroLlmToggle.querySelector('.hero-llm-chevron')?.classList.toggle('rotate-180', expanded);
      const label = heroLlmToggle.querySelector('.hero-llm-toggle-label');
      if (label) label.textContent = expanded ? heroLlmToggle.dataset.collapse || 'Collapse' : heroLlmToggle.dataset.expand || 'Show full prompt';
    });
  }
</script>

<style>
  /* Tab active state */
  .tab-btn.active { color: #111827; font-weight: 600; }
  .tab-btn.active::after {
    content: ''; position: absolute; bottom: -1px; left: 0; right: 0;
    height: 2px; background: #111827;
  }
  @media (prefers-color-scheme: dark) {
    .tab-btn.active { color: #f9fafb; }
    .tab-btn.active::after { background: #f9fafb; }
  }
  /* Win/LLM panel restore display when not hidden */
  .cmd-panel:not(.hidden) { display: flex; }
  #cmd-llm:not(.hidden) { display: block; }
  /* Copy feedback */
  .copy-btn.copied { color: #16a34a !important; }
  /* Install accordion */
  .install-details { max-height: 0; overflow: hidden; transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1); }
  .install-details.open { max-height: 520px; }
  .install-toggle :global(svg) { transition: transform 0.25s ease; }
  .install-toggle.open :global(svg) { transform: rotate(180deg); }
</style>

