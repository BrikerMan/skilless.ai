---
import { Search, Globe, Video, Film } from 'lucide-astro';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const tools = [
  {
    icon: Search,
    name: t('tools.search.name'),
    desc: t('tools.search.desc'),
    iconClass: 'bg-blue-50 dark:bg-blue-950/40 text-blue-600 dark:text-blue-400',
  },
  {
    icon: Globe,
    name: t('tools.web.name'),
    desc: t('tools.web.desc'),
    iconClass: 'bg-emerald-50 dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-400',
  },
  {
    icon: Video,
    name: t('tools.ytd.name'),
    desc: t('tools.ytd.desc'),
    iconClass: 'bg-red-50 dark:bg-red-950/40 text-red-600 dark:text-red-400',
  },
  {
    icon: Film,
    name: t('tools.media.name'),
    desc: t('tools.media.desc'),
    iconClass: 'bg-violet-50 dark:bg-violet-950/40 text-violet-600 dark:text-violet-400',
  },
];
---

<section class="py-16 bg-gray-50 dark:bg-gray-950/50 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">{t('tools.title')}</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 max-w-md mx-auto leading-relaxed">{t('tools.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {tools.map(tool => (
        <div class="group border border-gray-200 dark:border-gray-800 rounded-xl p-5 flex gap-4 bg-white dark:bg-gray-900 hover:-translate-y-0.5 hover:shadow-md hover:border-gray-300 dark:hover:border-gray-700 transition-all duration-200">
          <div class={`w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 ${tool.iconClass}`}>
            <tool.icon size={20} strokeWidth={1.5} />
          </div>
          <div class="min-w-0">
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">{tool.name}</h3>
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{tool.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
