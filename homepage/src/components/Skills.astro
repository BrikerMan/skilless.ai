---
import { Lightbulb, BookOpen, PenTool } from 'lucide-astro';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const skills = [
  {
    icon: Lightbulb,
    name: t('skills.brainstorm.name'),
    desc: t('skills.brainstorm.desc'),
    iconClass: 'bg-amber-50 dark:bg-amber-950/40 text-amber-600 dark:text-amber-400',
  },
  {
    icon: BookOpen,
    name: t('skills.research.name'),
    desc: t('skills.research.desc'),
    iconClass: 'bg-indigo-50 dark:bg-indigo-950/40 text-indigo-600 dark:text-indigo-400',
  },
  {
    icon: PenTool,
    name: t('skills.writing.name'),
    desc: t('skills.writing.desc'),
    iconClass: 'bg-emerald-50 dark:bg-emerald-950/40 text-emerald-600 dark:text-emerald-400',
  },
];
---

<section class="py-16 border-t border-gray-200 dark:border-gray-800">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">{t('skills.title')}</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 max-w-md mx-auto leading-relaxed">{t('skills.subtitle')}</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {skills.map(skill => (
        <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6 bg-white dark:bg-gray-900 hover:-translate-y-0.5 hover:shadow-md hover:border-gray-300 dark:hover:border-gray-700 transition-all duration-200">
          <div class={`w-10 h-10 rounded-xl flex items-center justify-center mb-4 ${skill.iconClass}`}>
            <skill.icon size={20} strokeWidth={1.5} />
          </div>
          <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">{skill.name}</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{skill.desc}</p>
        </div>
      ))}
    </div>

    <!-- Skill workflow chain -->
    <div class="mt-8 flex items-center justify-center gap-3 text-sm text-gray-400 dark:text-gray-500">
      <span class="px-3 py-1.5 rounded-lg bg-amber-50 dark:bg-amber-950/30 text-amber-600 dark:text-amber-400 font-medium">{t('skills.brainstorm.name')}</span>
      <span>&rarr;</span>
      <span class="px-3 py-1.5 rounded-lg bg-indigo-50 dark:bg-indigo-950/30 text-indigo-600 dark:text-indigo-400 font-medium">{t('skills.research.name')}</span>
      <span>&rarr;</span>
      <span class="px-3 py-1.5 rounded-lg bg-emerald-50 dark:bg-emerald-950/30 text-emerald-600 dark:text-emerald-400 font-medium">{t('skills.writing.name')}</span>
    </div>
    <p class="text-center text-xs text-gray-400 dark:text-gray-500 mt-2">{t('skills.workflow')}</p>
  </div>
</section>
