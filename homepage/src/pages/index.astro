---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import UseCases from '../components/UseCases.astro';
import CoreTools from '../components/CoreTools.astro';
import Skills from '../components/Skills.astro';
import GettingStarted from '../components/GettingStarted.astro';
import Highlights from '../components/Highlights.astro';
import FAQ from '../components/FAQ.astro';
import About from '../components/About.astro';
import Footer from '../components/Footer.astro';

const lang = 'en' as const;
---

<BaseLayout lang={lang}>
  <Nav lang={lang} />
  <Hero lang={lang} />
  <UseCases lang={lang} />
  <CoreTools lang={lang} />
  <Skills lang={lang} />
  <GettingStarted lang={lang} />
  <Highlights lang={lang} />
  <FAQ lang={lang} />
  <About lang={lang} />
  <Footer lang={lang} />
</BaseLayout>
